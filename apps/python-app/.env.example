# Copy this file to `.env` and fill in the value. `.env` is gitignored.
#
# Token used by the capability services to call the GitHub API. Needs:
#   - read:packages   (list GHCR container packages + tags)
#   - issues read     (repo / public_repo scope on a classic PAT)
# See the README section "Obtaining a GitHub token".
GITHUB_TOKEN=
