# Python virtualenvs and caches (CSSC Dashboard local dev)
.venv/
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
.coverage

# Helm: vendored subchart archives + lockfile (rebuilt via `helm dependency build`)
deploy/helm/*/charts/
deploy/helm/*/Chart.lock

# Local secrets/config (never commit the token); copy .env.example -> .env
.env
.env.local
